{
  "name": "mise-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "icons:generate": "node scripts/generate-icons.mjs",
    "db:reset": "supabase db reset --db-url \"$DATABASE_URL_DIRECT\" --yes",
    "db:push": "supabase db push --db-url \"$DATABASE_URL_DIRECT\"",
    "db:diff": "supabase db diff -f",
    "types:db": "supabase gen types typescript --db-url \"$DATABASE_URL_DIRECT\" --schema public > src/types/db.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-intl": "^4.11.0",
    "next-pwa": "^5.6.0",
    "openai": "^6.35.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
